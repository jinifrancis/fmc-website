---
import { useTranslations } from '../i18n/utils';
import SectionHeader from './SectionHeader.astro';
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="hall-sec" id="hall">
  <div class="inner">
    <SectionHeader eye={t('hall.eye')} title={t('hall.title')} lead={t('hall.lead')} />

    <div class="hall-grid">
      <!-- Left: Hall Image Placeholder -->
      <div class="hall-visual rv d1">
        <div class="hall-img-frame">
          <img src="/assets/images/parish_hall_morning.jpeg" alt="Fathima Matha Parish Hall" loading="lazy">
        </div>
        <div class="hall-img-frame">
          <img src="/assets/images/parish_hall_night.jpeg" alt="Fathima Matha Parish Hall" loading="lazy">
        </div>
        <div class="hall-features">
          <div class="hall-feature">
            <span class="hf-icon">👥</span>
            <span class="hf-text">{t('hall.feature.seating')}</span>
          </div>
          <div class="hall-feature">
            <span class="hf-icon">❄️</span>
            <span class="hf-text">{t('hall.feature.ac')}</span>
          </div>
        </div>
      </div>

      <div class="hall-content rv d2">
        <h3 class="hall-h">{t('hall.name')}</h3>
        <p class="hall-p" set:html={t('hall.description')}></p>

        <div class="hall-divider"></div>

        <h4 class="hall-subh">{t('hall.bookingTitle')}</h4>
        <p class="hall-p">{t('hall.bookingText')}</p>

        <div class="hall-booking-box">
          <h4 class="hb-title">{t('hall.booking.title')}</h4>
          <div class="hb-contact">
            <div class="hb-row">
              <span class="hb-label">{t('hall.booking.contact')}</span>
              <span class="hb-val">{t('hall.booking.contactName')}</span>
            </div>
            <div class="hb-row">
              <span class="hb-label">{t('hall.booking.phone')}</span>
              <span class="hb-val"><a href="tel:+919072119336">+91 90721 19336</a></span>
            </div>
            <div class="hb-row">
              <span class="hb-label">{t('hall.booking.timings')}</span>
              <span class="hb-val">{t('hall.booking.timingsVal')}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
