---
import { useTranslations, useTranslatedPath } from '../i18n/utils';
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="timings-sec" id="timings">
  <div class="inner">
    <div class="sec-hdr rv">
      <div class="sec-eye">{t('timings.eye')}</div>
      <h2 class="sec-title" set:html={t('timings.title')}></h2>
      <p class="sec-lead">{t('timings.lead')}</p>
    </div>
    <div class="t-grid">
      <!-- Sunday -->
      <div class="t-card rv d1">
        <div class="t-day">{t('timings.sunday')}</div>
        <ul class="t-rows">
          <li class="t-row">
            <div class="t-type">
              {t('timings.familyMass')}
              <span class="t-detail">{t('timings.malayalam')}</span>
            </div>
            <span class="t-time">7:00 AM</span>
          </li>
          <li class="t-row">
            <div class="t-type">
              {t('timings.childrenMass')}
              <span class="t-detail">{t('timings.catechism')}</span>
            </div>
            <span class="t-time">9:30 AM</span>
          </li>
          <li class="t-row">
            <div class="t-type">
              {t('timings.familyMass')}
              <span class="t-detail">{t('timings.malayalam')}</span>
            </div>
            <span class="t-time">4:00 PM</span>
          </li>
        </ul>
      </div>
      <!-- Other Days -->
      <div class="t-card rv d2">
        <div class="t-day">{t('timings.otherDays')}</div>
        <ul class="t-rows">
          <li class="t-row">
            <div class="t-type">
              {t('timings.morningMass')}
              <span class="t-detail">{t('timings.monThu')}</span>
            </div>
            <span class="t-time">6:30 AM</span>
          </li>
          <li class="t-row">
            <div class="t-type">
              {t('timings.eveningMass')}
              <span class="t-detail">{t('timings.friday')}</span>
            </div>
            <span class="t-time">5:30 PM</span>
          </li>
        </ul>
      </div>
    </div>
    <p class="t-notice rv" set:html={t('timings.notice')}></p>
  </div>
</section>
