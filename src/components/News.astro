---
import { useTranslations, useTranslatedPath } from '../i18n/utils';
import CardSkeleton from './CardSkeleton.astro';
const { lang } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<section class="news-sec">
  <div class="inner">
    <div class="sec-hdr rv">
      <div class="sec-eye">{t('news.eye')}</div>
      <h2 class="sec-title" set:html={t('news.title')}></h2>
      <p class="sec-lead">{t('news.lead')}</p>
    </div>

    <div class="news-grid" id="news-grid" data-lang={lang}>
      <CardSkeleton />
    </div>
    <p class="ann-empty" id="news-empty" style="display:none;">{t('ann.empty')}</p>

    <div class="news-view-all rv">
      <a href={translatePath('/announcements')} class="btn btn-gold">{t('news.view_all')}</a>
    </div>
  </div>
</section>

<script>
import { useTranslations } from '../i18n/utils';
import { fetchAndRenderAnnouncements } from '../lib/newsUtils';

const grid = document.getElementById('news-grid');
const emptyMsg = document.getElementById('news-empty');
if (!grid) throw new Error('news-grid not found');

const lang = grid.dataset.lang || 'ml';
const t = useTranslations(lang);

fetchAndRenderAnnouncements(grid, lang, t, { limit: 3, emptyEl: emptyMsg });
</script>
