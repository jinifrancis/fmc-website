---
import { useTranslations, useTranslatedPath } from '../i18n/utils';
import CardSkeleton from './CardSkeleton.astro';
import SectionHeader from './SectionHeader.astro';
const { lang } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<section class="news-sec" id="announcements">
  <div class="inner">
    <SectionHeader eye={t('news.eye')} title={t('news.title')} lead={t('news.lead')} />

    <div class="news-grid" id="news-grid" data-lang={lang}>
      <CardSkeleton />
    </div>
    <p class="ann-empty" id="news-empty" style="display:none;">{t('ann.empty')}</p>

    <div class="news-view-all rv">
      <a href={translatePath('/announcements')} class="btn btn-gold">{t('news.view_all')}</a>
    </div>
  </div>
</section>

<script>
  import { initAnnouncementGrid } from '../lib/initAnnouncementGrid';
  initAnnouncementGrid('news-grid', 'news-empty', 3);
</script>
