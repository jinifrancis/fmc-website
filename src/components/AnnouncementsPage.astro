---
import CardSkeleton from './CardSkeleton.astro';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<main class="ann-main">
  <div class="ann-hero">
    <div class="inner">
      <p class="sec-eye">{t('news.eye')}</p>
      <h1 class="ann-hero-title" set:html={t('news.title')} />
      <p class="ann-hero-lead">{t('news.lead')}</p>
    </div>
  </div>

  <section class="ann-sec">
    <div class="inner">
      <div class="news-grid" id="ann-grid" data-lang={lang}>
        <CardSkeleton />
      </div>
      <p class="ann-empty" id="ann-empty" style="display:none;">{t('ann.empty')}</p>
    </div>
  </section>
</main>

<script>
import { useTranslations } from '../i18n/utils';
import { fetchAndRenderAnnouncements } from '../lib/newsUtils';

const grid = document.getElementById('ann-grid');
const emptyMsg = document.getElementById('ann-empty');
if (!grid) throw new Error();

const lang = grid.dataset.lang || 'ml';
const t = useTranslations(lang);

fetchAndRenderAnnouncements(grid, lang, t, { emptyEl: emptyMsg });
</script>
