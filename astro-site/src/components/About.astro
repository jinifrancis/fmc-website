---
import { useTranslations } from '../i18n/utils';
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="about-sec" id="about">
  <div class="inner">
    <div class="sec-hdr rv">
      <div class="sec-eye">{t('about.eye')}</div>
      <h2 class="sec-title" set:html={t('about.title')}></h2>
      <p class="sec-lead">{t('about.lead')}</p>
    </div>
    <div class="about-grid">
      <!-- Left: Images -->
      <div class="about-left rv">
        <div class="church-frame">
          <img src="/assets/images/fmc_west_koratty.jpg" alt="Fathima Matha Church, West Koratty">
        </div>
        <div class="mary-row">
          <div class="mary-frame">
            <img src="/assets/images/fathima_matha.png" alt="Our Lady of Fatima statue">
          </div>
          <div class="parish-badges">
            <div class="p-badge">
              <span class="p-badge-icon">🏠</span>
              <div>
                <span class="p-badge-label">{t('about.badge.families')}</span>
                <span class="p-badge-val">{t('about.badge.familiesVal')}</span>
              </div>
            </div>
            <div class="p-badge">
              <span class="p-badge-icon">🙏</span>
              <div>
                <span class="p-badge-label">{t('about.badge.faithful')}</span>
                <span class="p-badge-val">{t('about.badge.faithfulVal')}</span>
              </div>
            </div>
            <div class="p-badge">
              <span class="p-badge-icon">📅</span>
              <div>
                <span class="p-badge-label">{t('about.badge.established')}</span>
                <span class="p-badge-val">{t('about.badge.establishedVal')}</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Content -->
      <div class="about-right rv d2">
        <div class="rite-pill">✝ {t('about.rite')}</div>
        <h2 class="about-h" set:html={t('about.heading')}></h2>
        <p class="about-p" set:html={t('about.p1')}></p>
        <div class="heritage-divider">
          <span></span>
          <span class="heritage-label">{t('about.heritageLabel')}</span>
          <span></span>
        </div>
        <p class="about-p" set:html={t('about.p2')}></p>
        <p class="about-p" set:html={t('about.p3')}></p>

        <!-- Parish Groups -->
        <div class="groups-grid">
          <div class="grp">
            <span class="grp-abbr">{t('groups.clc')}</span>
            <span class="grp-name">{t('groups.clc.description')}</span>
          </div>
          <div class="grp">
            <span class="grp-abbr">{t('groups.kcym')}</span>
            <span class="grp-name">{t('groups.kcym.description')}</span>
          </div>
          <div class="grp">
            <span class="grp-abbr">{t('groups.women')}</span>
            <span class="grp-name">{t('groups.women.description')}</span>
          </div>
          <div class="grp">
            <span class="grp-abbr">{t('groups.svp')}</span>
            <span class="grp-name">{t('groups.svp.description')}</span>
          </div>
          <div class="grp">
            <span class="grp-abbr">{t('groups.choir')}</span>
            <span class="grp-name">{t('groups.choir.description')}</span>
          </div>
          <div class="grp">
            <span class="grp-abbr">{t('groups.cce')}</span>
            <span class="grp-name">{t('groups.cce.description')}</span>
          </div>
          <div class="grp">
            <span class="grp-abbr">{t('groups.altar')}</span>
            <span class="grp-name">{t('groups.altar.description')}</span>
          </div>
          <div class="grp">
            <span class="grp-abbr">{t('groups.graceRipples')}</span>
            <span class="grp-name">{t('groups.graceRipples.description')}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
