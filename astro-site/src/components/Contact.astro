---
import { useTranslations, useTranslatedPath } from '../i18n/utils';
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="contact-sec" id="contact">
  <div class="inner">
    <div class="sec-hdr rv">
      <div class="sec-eye">{t('contact.eye')}</div>
      <h2 class="sec-title" set:html={t('contact.title')}></h2>
      <p class="sec-lead">{t('contact.lead')}</p>
    </div>
    <div class="c-grid">
      <div class="rv d1">
        <div class="c-item">
          <div class="c-icon">📍</div>
          <div>
            <div class="c-label">{t('contact.address')}</div>
            <div class="c-val" set:html={t('contact.addressVal')}></div>
          </div>
        </div>
        <div class="c-item">
          <div class="c-icon">📞</div>
          <div>
            <div class="c-label">{t('contact.office')}</div>
            <div class="c-val">
              <a href="tel:+914802081689">+91 480 208 1689</a><br>
              <span style="font-size:0.82rem;color:var(--ink-faint);" set:html={t('contact.officeHours')}></span>
            </div>
          </div>
        </div>
        <div class="c-item">
          <div class="c-icon">✉️</div>
          <div>
            <div class="c-label">{t('contact.email')}</div>
            <div class="c-val">
              <div class="c-val"><a href="mailto:fathimamathawkty@gmail.com">fathimamathawkty@gmail.com</a></div>
            </div>
          </div>
        </div>
        <div class="c-item">
          <div class="c-icon">🕐</div>
          <div>
            <div class="c-label">{t('contact.hours')}</div>
            <div class="c-val" set:html={t('contact.hoursVal')}></div>
          </div>
        </div>
        <div class="c-item">
          <div class="c-icon">✝️</div>
          <div>
            <div class="c-label">{t('contact.sacristan')}</div>
            <div class="c-val">
              <a href="tel:+919594783182">+91 95947 83182</a><br>
              <span style="font-size:0.82rem;color:var(--ink-faint);">{t('contact.sacristanNote')}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Map -->
      <div class="map-wrap rv d2">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3926.1871213192644!2d76.3450029!3d10.246487399999998!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3b0803f3ca9f1e1b%3A0x6682dbcc96f4e57!2sFathima%20Matha%20Syro-Malabar%20Church%2C%20West%20Koratty!5e0!3m2!1sen!2sin!4v1771322906129!5m2!1sen!2sin"
          allowfullscreen="" loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Fathima Matha Church, West Koratty">
        </iframe>
        <a href="https://maps.app.goo.gl/FWau9otEtFMHf2qH7"
          target="_blank"
          rel="noopener noreferrer"
          class="map-cta">
          {t('contact.mapCta')}
        </a>
      </div>
    </div>
  </div>
</section>
