---
import { useTranslations, useTranslatedPath } from '../i18n/utils';
const { lang } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<section class="news-sec">
  <div class="inner">
    <div class="sec-hdr rv">
      <div class="sec-eye">{t('news.eye')}</div>
      <h2 class="sec-title" set:html={t('news.title')}></h2>
      <p class="sec-lead">{t('news.lead')}</p>
    </div>

    <div class="news-grid">
      <!-- News Card 1: Farewell -->
      <article class="news-card rv d1">
        <div class="news-badge">📢 Important</div>
        <h3 class="news-title">Farewell wishes to Fr. Jomon Paliakkara</h3>
        <p class="news-date">📅 February 22, 2026</p>
        <p class="news-excerpt">{t('news.farewell.p1')}</p>
        <p class="news-excerpt">{t('news.farewell.p2')}</p>
      </article>

      <!-- News Card 2: Parish Hall -->
      <article class="news-card rv d2">
        <div class="news-badge news-badge-success">{t('news.hall.badge')}</div>
        <h3 class="news-title">{t('news.hall.title')}</h3>
        <p class="news-date">{t('news.hall.date')}</p>
        <p class="news-excerpt">{t('news.hall.p1')}</p>
        <div class="news-cta">
          <a href={translatePath('/#hall')} class="news-link">{t('news.hall.link')}</a>
        </div>
      </article>
    </div>
  </div>
</section>
